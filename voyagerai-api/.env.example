# =============================================================================
# VoyagerAI API — configuration
# Copy this file to `.env` and fill in values from your Auth0 tenant.
# Full setup walkthrough: ../docs/AUTH0-TENANT-VOYAGERAI.md
# =============================================================================

# API port. Default 3002 (the AcmeBank API stays on 3001 so both demos can run side-by-side).
PORT=3002

# -----------------------------------------------------------------------------
# Auth0 tenant (Resource Server)
# -----------------------------------------------------------------------------
# Full tenant URL with https://
# Example: https://voyagerai-demo.us.auth0.com
ISSUER_BASE_URL=https://<your-tenant>.auth0.com

# API identifier (= JWT audience). Must match the SPA's VITE_AUTH0_AUDIENCE.
# See docs/AUTH0-TENANT-VOYAGERAI.md §1.
AUDIENCE=https://api.voyagerai.demo

# -----------------------------------------------------------------------------
# Auth0 Management API (M2M app)
# Required for: triggering Guardian push (CIBA), revoking 3rd-party grants.
# Required permissions: read:users, read:user_idp_tokens, read:client_grants,
# delete:client_grants, create:guardian_enrollment_tickets, read:guardian_enrollments
# See docs/AUTH0-TENANT-VOYAGERAI.md §7.
# -----------------------------------------------------------------------------
AUTH0_MGMT_DOMAIN=<your-tenant>.auth0.com
AUTH0_MGMT_CLIENT_ID=<mgmt-m2m-client-id>
AUTH0_MGMT_CLIENT_SECRET=<mgmt-m2m-client-secret>

# -----------------------------------------------------------------------------
# Manager (CIBA target — receives the Guardian push for Tier 3 trip approvals)
# Format: auth0|xxxxxxxxxxxxxxxxxxxx
# See docs/AUTH0-TENANT-VOYAGERAI.md §6.
# -----------------------------------------------------------------------------
AUTH0_MANAGER_USER_ID=auth0|xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# 1st-party Travel Agent (M2M, private_key_jwt — RFC 7521)
# See docs/AUTH0-TENANT-VOYAGERAI.md §3.
# -----------------------------------------------------------------------------
AUTH0_AGENT_CLIENT_ID=<travel-agent-client-id>

# Private key (PEM, RS256). Two ways to provide it — pick ONE:
#
#   (A) RECOMMENDED — point to a PEM file on disk (.gitignored):
#       1. Save your private key as voyagerai-api/agent-private.pem (the file
#          openssl produced — keep BEGIN/END headers, real newlines, no edits).
#       2. Uncomment the next line:
# AUTH0_AGENT_PRIVATE_KEY_FILE=./agent-private.pem
#
#   (B) Inline — only if you can't use a file. Must be one line, with literal \n
#       between every PEM line. Wrapping in double quotes is required.
#       Wrong: pasting the output of `base64 < agent-private.pem` (that's
#       double-encoded AND multi-line, dotenv silently truncates it).
# AUTH0_AGENT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...IDAQAB\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------------------------------
# LLM provider (OpenAI-compatible)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# Agent model. Examples: gpt-4o-mini, gpt-4o, claude-haiku-4-5, claude-sonnet-4-5
AGENT_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Portal URL — used to build deep links in CIBA push notifications.
# -----------------------------------------------------------------------------
PORTAL_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Phase 2 — Auth0 FGA (uncomment when configured; see §9)
# -----------------------------------------------------------------------------
# FGA_API_URL=https://api.us1.fga.dev
# FGA_STORE_ID=
# FGA_CLIENT_ID=
# FGA_CLIENT_SECRET=
# FGA_API_AUDIENCE=https://api.us1.fga.dev/

# -----------------------------------------------------------------------------
# Phase 3 — Token Vault (Google Calendar) — uncomment when configured; see §10
# -----------------------------------------------------------------------------
# GOOGLE_CALENDAR_CONNECTION_ID=
