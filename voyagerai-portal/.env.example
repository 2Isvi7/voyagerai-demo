# =============================================================================
# VoyagerAI Portal — Vite environment
# Copy this file to `.env` and fill in values from your Auth0 tenant.
# All client-exposed vars MUST start with VITE_.
# Full setup walkthrough: ../docs/AUTH0-TENANT-VOYAGERAI.md
# =============================================================================

# Auth0 tenant domain WITHOUT https://
# Example: voyagerai-demo.us.auth0.com
VITE_AUTH0_DOMAIN=<your-tenant>.auth0.com

# Client ID of the SPA "VoyagerAI Portal" (PKCE).
# See docs/AUTH0-TENANT-VOYAGERAI.md §2.
VITE_AUTH0_CLIENT_ID=<spa-client-id>

# API audience identifier (must match the API's AUDIENCE env var).
# See docs/AUTH0-TENANT-VOYAGERAI.md §1.
VITE_AUTH0_AUDIENCE=https://api.voyagerai.demo

# API base URL — VoyagerAI API runs on :3002 to coexist with the AcmeBank demo (:3001).
VITE_API_URL=http://localhost:3002

# (Phase 2B) Client ID of the 3rd-party "Personal AI Assistant" app.
# Created in Auth0 as a separate SPA — see docs/AUTH0-TENANT-VOYAGERAI.md §8.
# Authorized only for: read:trips, read:expenses (NOT book:travel — that's the demo).
VITE_PERSONAL_ASSISTANT_CLIENT_ID=<personal-assistant-client-id>
